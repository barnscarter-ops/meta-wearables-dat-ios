require 'base64'

default_platform(:ios)

platform :ios do
  desc "Build, archive, and upload to TestFlight"
  lane :deploy do
    keychain_name = "ci_keychain"
    keychain_pass = "ci_temp_pass"

    create_keychain(
      name: keychain_name,
      password: keychain_pass,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
      add_to_search_list: true
    )

    # Import Distribution cert so xcodebuild can sign the archive
    p12_path = "/tmp/dist_cert.p12"
    File.write(p12_path, Base64.decode64(ENV["DIST_CERT_P12_BASE64"]))
    import_certificate(
      certificate_path: p12_path,
      certificate_password: ENV["DIST_CERT_P12_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_pass
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"]
    )

    profile_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    FileUtils.mkdir_p(profile_dir)

    sigh(api_key: api_key, app_identifier: "com.carter.camerai", output_path: profile_dir)
    ios_profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]

    sigh(api_key: api_key, app_identifier: "com.carter.camerai.watchkitapp", output_path: profile_dir)
    watch_profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]

    repo_root = File.expand_path("..", __dir__)
    project_path = "#{repo_root}/samples/CameraAccess/CameraAccess.xcodeproj"

    update_project_provisioning(
      xcodeproj: project_path,
      profile: ios_profile_path,
      target_filter: "CameraAccess",
      build_configuration: "Release"
    )

    update_project_provisioning(
      xcodeproj: project_path,
      profile: watch_profile_path,
      target_filter: "CameraAccess Watch App",
      build_configuration: "Release"
    )

    # Pick a build number one higher than whatever is already on TestFlight, so every
    # deploy is unique regardless of manual uploads. CFBundleVersion is wired to
    # CURRENT_PROJECT_VERSION in both the iOS app (Info.plist) and the Watch app
    # (GENERATE_INFOPLIST_FILE), so one xcodebuild override bumps both.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.carter.camerai",
      platform: "ios",
      initial_build_number: 0
    )
    build_number = latest + 1

    # Archive manually with the Distribution identity so the export step is signed
    # for the App Store. With SKIP_INSTALL=YES on the Watch target the archive has a
    # single product, so xcodebuild writes ApplicationProperties correctly on its own.
    archive_path = "/tmp/CameraAccess.xcarchive"
    sh(
      "xcodebuild -scheme CameraAccess -project '#{project_path}' " \
      "-configuration Release -destination 'generic/platform=iOS' " \
      "-archivePath '#{archive_path}' CODE_SIGN_STYLE=Manual " \
      "CURRENT_PROJECT_VERSION=#{build_number} " \
      "DEVELOPMENT_TEAM=R9DLFUKL26 " \
      "\"CODE_SIGN_IDENTITY=Apple Distribution: Carter Barns (R9DLFUKL26)\" archive"
    )

    gym(
      project: project_path,
      scheme: "CameraAccess",
      skip_build_archive: true,
      archive_path: archive_path,
      export_method: "app-store",
      output_directory: "./build",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.carter.camerai" => "com.carter.camerai AppStore",
          "com.carter.camerai.watchkitapp" => "com.carter.camerai.watchkitapp AppStore"
        }
      }
    )

    # Upload via altool directly. fastlane's pilot (2.236.1) does not forward the
    # platform to altool, and altool cannot infer it from an IPA that embeds a
    # watchOS companion -> "Cannot determine the platform; please specify --platform".
    # Calling altool with an explicit --type ios sidesteps the inference entirely.
    key_dir = File.expand_path("~/.appstoreconnect/private_keys")
    FileUtils.mkdir_p(key_dir)
    File.write("#{key_dir}/AuthKey_#{ENV['ASC_KEY_ID']}.p8", ENV["ASC_KEY_CONTENT"])

    ipa_path = "#{repo_root}/build/CameraAccess.ipa"
    # altool's upload flag is --platform (alias -t), NOT --type. altool also exits 0
    # even when it prints a fatal ERROR, so we capture output and fail explicitly.
    upload_out = sh(
      "xcrun altool --upload-app -f '#{ipa_path}' --platform ios " \
      "--apiKey #{ENV['ASC_KEY_ID']} --apiIssuer #{ENV['ASC_ISSUER_ID']} 2>&1",
      log: true
    )
    unless upload_out.include?("No errors uploading")
      UI.user_error!("altool upload did not succeed:\n#{upload_out}")
    end
  end
end
