require 'base64'

default_platform(:ios)

platform :ios do
  desc "Build, archive, and upload to TestFlight"
  lane :deploy do
    keychain_name = "ci_keychain"
    keychain_pass = "ci_temp_pass"

    create_keychain(
      name: keychain_name,
      password: keychain_pass,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
      add_to_search_list: true
    )

    # Import Distribution cert so xcodebuild can sign the archive
    p12_path = "/tmp/dist_cert.p12"
    File.write(p12_path, Base64.decode64(ENV["DIST_CERT_P12_BASE64"]))
    import_certificate(
      certificate_path: p12_path,
      certificate_password: ENV["DIST_CERT_P12_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_pass
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"]
    )

    # Download AppStore profiles to the system directory so xcodebuild can find them.
    # PROVISIONING_PROFILE_SPECIFIER[sdk=...] conditional syntax does NOT work in xcargs
    # (xcodebuild splits on first '=' so the bracket becomes part of the key name).
    # Instead: set profiles per-target in the project file via update_project_provisioning.
    profile_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    FileUtils.mkdir_p(profile_dir)

    sigh(api_key: api_key, app_identifier: "com.carter.camerai", output_path: profile_dir)
    ios_profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]

    sigh(api_key: api_key, app_identifier: "com.carter.camerai.watchkitapp", output_path: profile_dir)
    watch_profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]

    project_path = "samples/CameraAccess/CameraAccess.xcodeproj"

    update_project_provisioning(
      xcodeproj: project_path,
      profile: ios_profile_path,
      target_filter: "CameraAccess",
      build_configuration: "Release"
    )

    update_project_provisioning(
      xcodeproj: project_path,
      profile: watch_profile_path,
      target_filter: "CameraAccess Watch App",
      build_configuration: "Release"
    )

    # Xcode 26: archive must be signed with Distribution cert upfront.
    # Per-target PROVISIONING_PROFILE (UUID) is already set by update_project_provisioning above.
    gym(
      scheme: "CameraAccess",
      project: project_path,
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      output_directory: "./build",
      xcargs: 'CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=R9DLFUKL26 CODE_SIGN_IDENTITY="Apple Distribution: Carter Barns (R9DLFUKL26)"',
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.carter.camerai" => "com.carter.camerai AppStore",
          "com.carter.camerai.watchkitapp" => "com.carter.camerai.watchkitapp AppStore"
        }
      }
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
