require 'base64'
require 'shellwords'
require 'etc'

default_platform(:ios)

platform :ios do
  desc "Build, archive, and upload to TestFlight"
  lane :deploy do
    keychain_name = "ci_keychain"
    keychain_pass = "ci_temp_pass"
    # Resolve the keychain to an ABSOLUTE path from the password database rather than a
    # bare name. `security` resolves a bare name via $HOME, and the runner's job process
    # launches with HOME="/", so a bare name resolves to /Library/Keychains (root-owned,
    # unwritable) and create-keychain dies with "UNIX[Permission denied]" (exit 173).
    # Etc.getpwuid.dir reads the real home from the directory service, ignoring $HOME.
    keychain_path = File.join(Etc.getpwuid.dir, "Library", "Keychains", keychain_name)

    # Set up the signing keychain with explicit `security` commands instead of
    # fastlane's create_keychain action, which runs every call with log:false and so
    # reports failures as an opaque "exit status 1" with no stderr. These surface the
    # real command output, and are idempotent (delete first) since the self-hosted
    # runner persists state between runs.
    kc = keychain_path.shellescape
    sh("security delete-keychain #{kc} 2>/dev/null || true")
    sh("security create-keychain -p #{keychain_pass} #{kc}")
    # 6h timeout, no -l/-u so the keychain never auto-locks mid-build.
    sh("security set-keychain-settings -t 21600 #{kc}")
    sh("security unlock-keychain -p #{keychain_pass} #{kc}")
    # Prepend our keychain to the user search list (keeping existing entries) so
    # codesign can find the Distribution identity.
    existing = sh("security list-keychains -d user", log: false).split("\n").map { |l| l.strip.delete('"') }.reject(&:empty?)
    sh("security list-keychains -d user -s #{kc} #{existing.shelljoin}")

    # Import Distribution cert so xcodebuild can sign the archive. set_partition_list
    # runs `security set-key-partition-list` so codesign can use the private key
    # non-interactively (no UI prompt) in the headless runner.
    p12_path = "/tmp/dist_cert.p12"
    File.write(p12_path, Base64.decode64(ENV["DIST_CERT_P12_BASE64"]))
    import_certificate(
      certificate_path: p12_path,
      certificate_password: ENV["DIST_CERT_P12_PASSWORD"],
      keychain_name: keychain_name,
      keychain_path: keychain_path,
      keychain_password: keychain_pass,
      set_partition_list: true
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"]
    )

    profile_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    FileUtils.mkdir_p(profile_dir)

    sigh(api_key: api_key, app_identifier: "com.carter.camerai", output_path: profile_dir)
    ios_profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]

    sigh(api_key: api_key, app_identifier: "com.carter.camerai.watchkitapp", output_path: profile_dir)
    watch_profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]

    repo_root = File.expand_path("..", __dir__)
    project_path = "#{repo_root}/samples/CameraAccess/CameraAccess.xcodeproj"

    update_project_provisioning(
      xcodeproj: project_path,
      profile: ios_profile_path,
      target_filter: "CameraAccess",
      build_configuration: "Release"
    )

    update_project_provisioning(
      xcodeproj: project_path,
      profile: watch_profile_path,
      target_filter: "CameraAccess Watch App",
      build_configuration: "Release"
    )

    # Pick a build number one higher than whatever is already on TestFlight, so every
    # deploy is unique regardless of manual uploads. CFBundleVersion is wired to
    # CURRENT_PROJECT_VERSION in both the iOS app (Info.plist) and the Watch app
    # (GENERATE_INFOPLIST_FILE), so one xcodebuild override bumps both.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.carter.camerai",
      platform: "ios",
      initial_build_number: 0
    )
    build_number = latest + 1

    # Bundle the OpenAI API key into the app. Secrets.plist is gitignored and is the
    # ONLY on-device source of the key (process env vars don't exist in an installed
    # TestFlight build), and the project now requires it as a build resource. So CI
    # materializes it from the OPENAI_API_KEY secret before archiving.
    openai_key = ENV["OPENAI_API_KEY"].to_s.strip
    if openai_key.empty?
      UI.user_error!("OPENAI_API_KEY is not set — the build would ship without a working API key.")
    end
    # A dead/rotated key looks identical to a live one until used, so authenticate it
    # against OpenAI now and fail the deploy loudly instead of shipping a build that
    # 401s on every AI call. Key is read from $OPENAI_API_KEY so it stays out of argv/logs.
    auth_code = sh(
      %(curl -s -o /dev/null -w '%{http_code}' https://api.openai.com/v1/models -H "Authorization: Bearer $OPENAI_API_KEY"),
      log: false
    ).strip
    unless auth_code == "200"
      UI.user_error!("OPENAI_API_KEY failed to authenticate with OpenAI (HTTP #{auth_code}) — aborting before build.")
    end
    secrets_plist = "#{repo_root}/samples/CameraAccess/CameraAccess/Secrets.plist"
    # OpenAI keys are [A-Za-z0-9_-] only, so no XML escaping is needed here.
    File.write(secrets_plist, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
          <key>OPENAI_API_KEY</key>
          <string>#{openai_key}</string>
      </dict>
      </plist>
    PLIST

    # Archive manually with the Distribution identity so the export step is signed
    # for the App Store. With SKIP_INSTALL=YES on the Watch target the archive has a
    # single product, so xcodebuild writes ApplicationProperties correctly on its own.
    archive_path = "/tmp/CameraAccess.xcarchive"
    sh(
      "xcodebuild -scheme CameraAccess -project '#{project_path}' " \
      "-configuration Release -destination 'generic/platform=iOS' " \
      "-archivePath '#{archive_path}' CODE_SIGN_STYLE=Manual " \
      "CURRENT_PROJECT_VERSION=#{build_number} " \
      "DEVELOPMENT_TEAM=R9DLFUKL26 " \
      "\"CODE_SIGN_IDENTITY=Apple Distribution: Carter Barns (R9DLFUKL26)\" archive"
    )

    gym(
      project: project_path,
      scheme: "CameraAccess",
      skip_build_archive: true,
      archive_path: archive_path,
      export_method: "app-store",
      output_directory: "./build",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.carter.camerai" => "com.carter.camerai AppStore",
          "com.carter.camerai.watchkitapp" => "com.carter.camerai.watchkitapp AppStore"
        }
      }
    )

    # Upload via altool directly. fastlane's pilot (2.236.1) does not forward the
    # platform to altool, and altool cannot infer it from an IPA that embeds a
    # watchOS companion -> "Cannot determine the platform; please specify --platform".
    # Calling altool with an explicit --type ios sidesteps the inference entirely.
    key_dir = File.expand_path("~/.appstoreconnect/private_keys")
    FileUtils.mkdir_p(key_dir)
    File.write("#{key_dir}/AuthKey_#{ENV['ASC_KEY_ID']}.p8", ENV["ASC_KEY_CONTENT"])

    ipa_path = "#{repo_root}/build/CameraAccess.ipa"
    # altool's upload flag is --platform (alias -t), NOT --type. altool also exits 0
    # even when it prints a fatal ERROR, so we capture output and fail explicitly.
    upload_out = sh(
      "xcrun altool --upload-app -f '#{ipa_path}' --platform ios " \
      "--apiKey #{ENV['ASC_KEY_ID']} --apiIssuer #{ENV['ASC_ISSUER_ID']} 2>&1",
      log: true
    )
    unless upload_out.include?("No errors uploading")
      UI.user_error!("altool upload did not succeed:\n#{upload_out}")
    end
  end
end
