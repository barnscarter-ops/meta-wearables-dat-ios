default_platform(:ios)

platform :ios do
  desc "Build, archive, and upload to TestFlight"
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"]
    )

    # xcodebuild needs the .p8 key on disk for -authenticationKeyPath
    key_path = "/tmp/AuthKey_#{ENV['ASC_KEY_ID']}.p8"
    File.write(key_path, ENV["ASC_KEY_CONTENT"])
    auth_flags = "-allowProvisioningUpdates -authenticationKeyPath #{key_path} -authenticationKeyID #{ENV['ASC_KEY_ID']} -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}"

    gym(
      scheme: "CameraAccess",
      project: "samples/CameraAccess/CameraAccess.xcodeproj",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      output_directory: "./build",
      xcargs: "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM=AC922H2743 #{auth_flags}",
      export_xcargs: auth_flags
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
