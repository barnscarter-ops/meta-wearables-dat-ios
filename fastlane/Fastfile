require 'base64'

default_platform(:ios)

platform :ios do
  desc "Build, archive, and upload to TestFlight"
  lane :deploy do
    keychain_name = "ci_keychain"
    keychain_pass = "ci_temp_pass"

    create_keychain(
      name: keychain_name,
      password: keychain_pass,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
      add_to_search_list: true
    )

    # Import Distribution cert so xcodebuild can sign the archive
    p12_path = "/tmp/dist_cert.p12"
    File.write(p12_path, Base64.decode64(ENV["DIST_CERT_P12_BASE64"]))
    import_certificate(
      certificate_path: p12_path,
      certificate_password: ENV["DIST_CERT_P12_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_pass
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"]
    )

    # Ensure profiles dir exists, then install AppStore Distribution profiles
    FileUtils.mkdir_p(File.expand_path("~/Library/MobileDevice/Provisioning Profiles"))
    sigh(api_key: api_key, app_identifier: "com.carter.camerai")
    sigh(api_key: api_key, app_identifier: "com.carter.camerai.watchkitapp")

    # Xcode 26 requires the archive to be signed with a Distribution cert upfront;
    # it no longer re-signs from Development during export. Use manual signing
    # with per-SDK profile specifiers so iOS and watchOS targets get distinct profiles.
    gym(
      scheme: "CameraAccess",
      project: "samples/CameraAccess/CameraAccess.xcodeproj",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      output_directory: "./build",
      xcargs: %q(CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=R9DLFUKL26 CODE_SIGN_IDENTITY="Apple Distribution: Carter Barns (R9DLFUKL26)" "PROVISIONING_PROFILE_SPECIFIER[sdk=iphoneos*]=com.carter.camerai AppStore" "PROVISIONING_PROFILE_SPECIFIER[sdk=watchos*]=com.carter.camerai.watchkitapp AppStore"),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.carter.camerai" => "com.carter.camerai AppStore",
          "com.carter.camerai.watchkitapp" => "com.carter.camerai.watchkitapp AppStore"
        }
      }
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
